{
  "name": "workspace",
  "version": "1.0.0",
  "type": "module",
  "description": "A modern Challenge Management API built with Node.js, Express, Prisma ORM, Drizzle ORM, and PostgreSQL. This API provides comprehensive CRUD operations for managing challenges with advanced features like source tracking, filtering, and pagination.",
  "main": "dist/server.js",
  "scripts": {
    "build": "rimraf dist && tsc && node scripts/copy-assets.js",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build-frontend": "npm run build --prefix frontend",
    "seed": "node scripts/seed.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.9",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "mongodb": "^6.5.0",
    "postgres": "^3.4.4",
    "prisma": "^6.11.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/swagger-ui-express": "^4.1.6",
    "drizzle-kit": "^0.20.17",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
